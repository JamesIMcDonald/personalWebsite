generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id               Int     @id @default(autoincrement())
  email            String  @unique @db.VarChar(100)
  username         String? @db.VarChar(100)
  google_id        String  @unique @db.VarChar(255)

  jobs             jobs[]
  refreshSessions  refresh_sessions[]
}

model refresh_sessions {
  id         Int       @id @default(autoincrement())
  user       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int
  jti        String    @unique @db.Uuid
  token_hash String    @unique @db.VarChar(64)
  expires_at DateTime  @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)


  @@index([user_id])
  @@index([expires_at])
}

model contact_submission {
  id        Int      @id @default(autoincrement())
  email     String
  comments  String
  createdAt DateTime @default(now())
}

model jobs {
  id         Int       @id @default(autoincrement())
  job_type   String    @db.VarChar(255)
  job_status String    @db.VarChar(255)
  user       users     @relation(fields: [user_id], references: [id])
  user_id    Int   
  data       Json      @default("{}")
  
  link_checker_pages   link_checker_pages[]
  link_checker_links   link_checker_links[]
  overture_maps_places overture_maps_places[]
}

model link_checker_links {
  id          BigInt             @id @default(autoincrement())
  job         jobs               @relation(fields: [job_id], references: [id])
  job_id      Int
  from_page   link_checker_pages @relation("FromPageLinks", fields: [from_url_id], references: [id])
  from_url_id BigInt
  to_page     link_checker_pages @relation("ToPageLinks", fields: [to_url_id], references: [id])
  to_url_id   BigInt

  @@index([job_id, from_url_id])
  @@index([job_id, to_url_id])
}

// the @@unique at the bottom meshes with the @@ indexes above to make sure that we can only add links to a page belonging to the same job it is NOT useless
model link_checker_pages {
  id              BigInt    @id @default(autoincrement())
  job             jobs      @relation(fields: [job_id], references: [id])
  job_id          Int
  url             String
  fetched_at      DateTime? @db.Timestamp(6)
  destination_url String?

  outgoing_links  link_checker_links[] @relation("FromPageLinks")
  incoming_links  link_checker_links[] @relation("ToPageLinks")
 
  @@unique([job_id, id])
}

model overture_maps_places {
  id                Int       @id @default(autoincrement())
  job               jobs      @relation(fields: [job_id], references: [id])
  job_id            Int
  map_id            String
  name              String?
  category          String?
  basic_category    String?
  confidence        Decimal?
  operating_status  String    @db.VarChar(25)
  address           String?
  postcode          String?
  website           String?
  phone             String?
  latitude          Decimal
  longitude         Decimal
}